






# ===== Comic project environment =====
USE_MOCK_PROVIDERS=false

# 真实 provider 失败时是否允许回退 mock
ALLOW_MOCK_IMAGE_FALLBACK=false
ALLOW_MOCK_TEXT_FALLBACK=false
ALLOW_MOCK_SEGMENT_FALLBACK=false
PROVIDER_TIMEOUT_SECONDS=120

# Qwen: storyboard / reference selection / revision planning / ref note
QWEN_API_KEY=sk-lFb1ZYGIcFltQlLeVpdSeCMtngg8dKEsUUugKyyGVBVhSuO1
QWEN_BASE_URL=https://xuedingmao.top/v1/chat/completions
QWEN_MODEL=qwen3.6-plus

# OpenAI-compatible text fallback + GPT Image
OPENAI_API_KEY=sk-1xdlN8QWownuaIsco12oZbOi1hRF34IDJ36JIOdXcJJtCSap
OPENAI_BASE_URL=https://xuedpletions
OPENAI_TEXT_API_KEY=sk-6jtioIVDhAHBE3EwW3v8XW39sHoPQ3b8M6T1NXm3IPcdn9ot
OPENAI_TEXT_BASE_URL=https://xuedingmao.top/v1/chat/completions
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_IMAGE_API_KEY=sk-1xdlN8QWownuaIsco12oZbOi1hRF34IDJ36JIOdXcJJtCSap
OPENAI_IMAGE_MODEL=gpt-image-2

# 图像接口。panel 生成会用 edits，因为它要输入 reference sheet 图片。
OPENAI_IMAGE_BASE_URL=https://xuedingmao.top/v1
OPENAI_IMAGE_EDITS_ENDPOINT=/v1/images/edits
OPENAI_IMAGE_GENERATIONS_ENDPOINT=/v1/images/generations


# SAM3.1 segmentation endpoint。启动 sam3_service 后就用这个。
SAM3_ENDPOINT=http://127.0.0.1:8100/segment

# SAM3.1 standalone service config
SAM3_SERVICE_HOST=0.0.0.0
SAM3_SERVICE_PORT=8100
SAM3_DEVICE=cuda
SAM3_VERSION=sam3.1
SAM3_IMAGE_VERSION=sam3
SAM3_CHECKPOINT_PATH=
SAM3_PROMPT_MODE=entity_id
SAM3_SCORE_THRESHOLD=0.0
SAM3_MAX_PROMPT_CHARS=120
SAM3_COMPILE=false
SAM3_ALLOW_SAM3_FALLBACK=false
SAM3_ALPHA_BLUR_RADIUS=0

# 输出目录。相对路径会解析到 backend/ 下，例如 outputs => backend/outputs
alhost:3000,http://127.0.0.1:3000

# 前端浏览器访问后端的地址。服务器部署时改成你的后端公网地址。
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
SAM3_DTYPE=bfloat16
SAM3_NO_MASK_FALLBACK=foreground
SAM3_FOREGROUND_THRESHOLD=245
