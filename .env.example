# Copy this file to .env on the server, then fill real keys.

USE_MOCK_PROVIDERS=false
ALLOW_MOCK_IMAGE_FALLBACK=true
ALLOW_MOCK_TEXT_FALLBACK=true
ALLOW_MOCK_SEGMENT_FALLBACK=true
PROVIDER_TIMEOUT_SECONDS=120

QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=

OPENAI_API_KEY=
OPENAI_BASE_URL=

# Text API. Prefer these over legacy OPENAI_API_KEY / OPENAI_BASE_URL.
OPENAI_TEXT_API_KEY=
OPENAI_TEXT_BASE_URL=
OPENAI_TEXT_MODEL=

# Image API. Prefer these over legacy OPENAI_API_KEY / OPENAI_BASE_URL.
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_MODEL=

# Recommended for image APIs. Panel generation uses edits because it sends the reference sheet image.
OPENAI_IMAGE_BASE_URL=
OPENAI_IMAGE_EDITS_ENDPOINT=/v1/images/edits
OPENAI_IMAGE_GENERATIONS_ENDPOINT=/v1/images/generations

# Legacy fallback. Prefer the three image settings above.
OPENAI_IMAGE_ENDPOINT=

OUTPUT_DIR=outputs
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# SAM 3.1 service
SAM3_ENDPOINT=http://127.0.0.1:8100/segment
SAM3_SERVICE_HOST=0.0.0.0
SAM3_SERVICE_PORT=8100
SAM3_DEVICE=cuda
SAM3_DTYPE=bfloat16
SAM3_VERSION=sam3.1
SAM3_IMAGE_VERSION=sam3
SAM3_CHECKPOINT_PATH=
SAM3_PROMPT_MODE=entity_id
SAM3_SCORE_THRESHOLD=0.15
SAM3_MAX_PROMPT_CHARS=120
SAM3_NO_MASK_FALLBACK=foreground
SAM3_FOREGROUND_THRESHOLD=245
SAM3_COMPILE=false
SAM3_ALLOW_SAM3_FALLBACK=false
SAM3_ALPHA_BLUR_RADIUS=0
