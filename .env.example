# Copy this file to .env on the server, then fill real keys.

USE_MOCK_PROVIDERS=false
ALLOW_MOCK_IMAGE_FALLBACK=true
ALLOW_MOCK_TEXT_FALLBACK=true
ALLOW_MOCK_SEGMENT_FALLBACK=true
PROVIDER_TIMEOUT_SECONDS=120

QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODEL=

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_TEXT_MODEL=
OPENAI_IMAGE_MODEL=
OPENAI_IMAGE_ENDPOINT=

OUTPUT_DIR=outputs
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# SAM 3.1 service
SAM3_ENDPOINT=http://127.0.0.1:8100/segment
SAM3_SERVICE_HOST=0.0.0.0
SAM3_SERVICE_PORT=8100
SAM3_DEVICE=cuda
SAM3_VERSION=sam3.1
SAM3_CHECKPOINT_PATH=
SAM3_PROMPT_MODE=combined
SAM3_SCORE_THRESHOLD=0.15
SAM3_MAX_PROMPT_CHARS=120
SAM3_COMPILE=false
SAM3_ALLOW_SAM3_FALLBACK=false
SAM3_ALPHA_BLUR_RADIUS=0
