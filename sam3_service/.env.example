# SAM 3.1 service config
SAM3_SERVICE_HOST=0.0.0.0
SAM3_SERVICE_PORT=8100
SAM3_DEVICE=cuda
SAM3_VERSION=sam3.1

# Optional. If empty, service downloads from Hugging Face after hf auth login.
SAM3_CHECKPOINT_PATH=

# combined | entity_id | description
SAM3_PROMPT_MODE=combined
SAM3_SCORE_THRESHOLD=0.15
SAM3_MAX_PROMPT_CHARS=120
SAM3_COMPILE=false

# If SAM3.1 checkpoint loading fails, allow falling back to base SAM3.
SAM3_ALLOW_SAM3_FALLBACK=false
SAM3_ALPHA_BLUR_RADIUS=0

# Main backend should call this:
SAM3_ENDPOINT=http://127.0.0.1:8100/segment
